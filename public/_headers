# Cloudflare Pages header rules for the docs site.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# React Router emits hashed assets — safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML — keep edge cached briefly so deploys propagate quickly.
/
  Cache-Control: public, max-age=300, must-revalidate
/index.html
  Cache-Control: public, max-age=300, must-revalidate

# Fumadocs search index / sitemap, if generated.
/sitemap.xml
  Cache-Control: public, max-age=86400
/robots.txt
  Cache-Control: public, max-age=86400
